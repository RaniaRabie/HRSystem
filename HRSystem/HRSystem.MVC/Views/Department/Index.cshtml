@model IEnumerable<DepartmentVM>

@{
    ViewData["Title"] = "Departments";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 rounded-3 py-2 small">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 rounded-3 py-2 small">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
    </div>
}

<div class="card">
    <div class="card-header bg-white border-0 py-3 px-4
        d-flex justify-content-between align-items-center">
        <span class="fw-semibold" style="font-size:14px;">
            All Departments
            <span class="badge bg-primary bg-opacity-10 text-primary ms-2 fw-normal">
                @Model.Count()
            </span>
        </span>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Add Department
        </a>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Manager</th>
                    <th>Positions</th>
                    <th>Employees</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No departments yet
                        </td>
                    </tr>
                }

                @foreach (var dept in Model)
                {
                    <tr>
                        <td class="fw-medium">@dept.Name</td>
                        <td class="text-muted">@dept.MgrName</td>
                        <td>@dept.PositionsCount</td>
                        <td>@dept.EmployeeCount</td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@dept.Id"
                               class="btn btn-outline-primary btn-sm me-1">
                                <i class="bi bi-pencil"></i> Edit
                            </a>

                            <form asp-action="Delete" asp-route-id="@dept.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @dept.Name?')">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>