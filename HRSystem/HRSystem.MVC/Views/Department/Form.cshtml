@model HRSystem.BLL.ModelVM.Department.DepartmentFormVM

@{
    bool isEdit = Model.Id != null;
    ViewData["Title"] = isEdit ? "Edit Department" : "Create Department";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-white border-0 py-3 px-4">
                <h6 class="mb-0 fw-semibold">@ViewData["Title"]</h6>
            </div>

            <div class="card-body px-4 pb-4">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()

                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger py-2 small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Department Name</label>
                        <input asp-for="Name" class="form-control"
                               placeholder="e.g. Engineering" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ManagerId" class="form-label">
                            Manager
                            <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <select asp-for="ManagerId" class="form-select">
                            <option value="">— No Manager —</option>
                            @foreach (var emp in ViewBag.Managers)
                            {
                                <option value="@emp.Id">@emp.FullName</option>
                            }
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>
                            @(isEdit ? "Save Changes" : "Create Department")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}