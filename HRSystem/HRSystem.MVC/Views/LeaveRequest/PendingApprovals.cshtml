@model IEnumerable<HRSystem.BLL.ModelVM.LeaveRequest.LeaveRequestVM>

@{
    ViewData["Title"] = "Pending Approvals";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 rounded-3 py-2 small">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 rounded-3 py-2 small">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
    </div>
}

<div class="card">
    <div class="card-header bg-white border-0 py-3 px-4">
        <span class="fw-semibold" style="font-size:14px;">
            Pending Approvals
            <span class="badge bg-warning bg-opacity-15 text-white ms-2 fw-normal">
                @Model.Count()
            </span>
        </span>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Type</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Days</th>
                    <th>Reason</th>
                    <th>Decision</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            No pending requests
                        </td>
                    </tr>
                }

                @foreach (var r in Model)
                {
                    <tr>
                        <td class="fw-medium">@r.EmployeeName</td>
                        <td>@r.LeaveTypeName</td>
                        <td>@r.FromDate.ToString("dd MMM yyyy")</td>
                        <td>@r.ToDate.ToString("dd MMM yyyy")</td>
                        <td>@r.TotalDays</td>
                        <td class="text-muted" style="font-size:12px; max-width:180px;">
                            @r.Reason
                        </td>
                        <td>
                            <!-- Inline approval form -->
                            <form asp-action="ProcessApproval" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="LeaveRequestId"
                                       value="@r.Id" />

                                <div class="mb-2">
                                    <input type="text" name="Note"
                                           class="form-control form-control-sm"
                                           placeholder="Note (optional)" />
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit"
                                            name="Decision" value="1"
                                            class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-check-lg"></i> Approve
                                    </button>
                                    <button type="submit"
                                            name="Decision" value="2"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Reject this request?')">
                                        <i class="bi bi-x-lg"></i> Reject
                                    </button>
                                </div>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>