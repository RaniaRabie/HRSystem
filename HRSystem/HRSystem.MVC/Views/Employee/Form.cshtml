@model HRSystem.BLL.ModelVM.Employee.EmployeeFormVM

@{
    bool isEdit = Model.Id != null;
    ViewData["Title"] = isEdit ? "Edit Employee" : "Add Employee";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-white border-0 py-3 px-4">
                <h6 class="mb-0 fw-semibold">@ViewData["Title"]</h6>
            </div>

            <div class="card-body px-4 pb-4">
                <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
                    @Html.AntiForgeryToken()

                    @if (isEdit)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger py-2 small mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label">First Name</label>
                            <input asp-for="FirstName" class="form-control"
                                   placeholder="Sara" />
                            <span asp-validation-for="FirstName" 
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label">Last Name</label>
                            <input asp-for="LastName" class="form-control"
                                   placeholder="Ahmed" />
                            <span asp-validation-for="LastName" 
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" class="form-control"
                               placeholder="sara@company.com"
                               readonly="@(isEdit)" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    @if (!isEdit)
                    {
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Password</label>
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="Min. 8 characters" />
                            <span asp-validation-for="Password" 
                                  class="text-danger small"></span>
                        </div>
                    }
                    

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Salary" class="form-label">Salary</label>
                            <input asp-for="Salary" type="number" class="form-control"
                                   placeholder="0.00" step="0.01" />
                            <span asp-validation-for="Salary" 
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="HireDate" class="form-label">Hire Date</label>
                            <input asp-for="HireDate" type="date" class="form-control" />
                            <span asp-validation-for="HireDate" 
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PositionId" class="form-label">Position</label>
                        <select asp-for="PositionId" class="form-select">
                            <option value="">— Select Position —</option>
                            @foreach (var pos in ViewBag.Positions)
                            {
                                <option value="@pos.Id">
                                    @pos.Name (@pos.DepartmentName)
                                </option>
                            }
                        </select>
                        <span asp-validation-for="PositionId" 
                              class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Role" class="form-label">Role</label>
                        <select asp-for="Role" class="form-select">
                            <option value="Employee">Employee</option>
                            <option value="HR">HR</option>
                            <option value="Admin">Admin</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger small"></span>
                    </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="SupervisorId" class="form-label">
                            Supervisor
                            <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <select asp-for="SupervisorId" class="form-select">
                            <option value="">— No Supervisor —</option>
                            @foreach (var sup in ViewBag.Supervisors)
                            {
                                <option value="@sup.Id">@sup.FullName</option>
                            }
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>
                            @(isEdit ? "Save Changes" : "Add Employee")
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}